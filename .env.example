# ============================================================
# The Stellaar Club — Environment Variables
# Copy this to .env.local and fill in your values.
# ============================================================

# --- Supabase (PostgreSQL / SQL Database) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Google Sheets API (Service Account) ---
# 1. Go to https://console.cloud.google.com
# 2. Create a project or select existing one
# 3. Enable the Google Sheets API
# 4. Create a Service Account & download the JSON key
# 5. Share your Google Sheet with the service account email (Editor)
# 6. Copy the Sheet ID from the URL: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id
